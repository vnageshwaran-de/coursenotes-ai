# ─── LLM Provider ────────────────────────────────────────────────
# Supported: groq | gemini | ollama | openrouter
LLM_PROVIDER=groq

# API key for the chosen provider
# Groq:       https://console.groq.com  (free tier available)
# Gemini:     https://aistudio.google.com/app/apikey  (free tier available)
# OpenRouter: https://openrouter.ai/keys  (free models available)
# Ollama:     leave blank (runs fully locally)
LLM_API_KEY=your_api_key_here

# Model to use (leave blank to use provider default)
# Groq default:       llama3-groq-70b-8192-tool-use-preview
# Gemini default:     gemini-2.0-flash
# Ollama default:     llama3
# OpenRouter default: meta-llama/llama-3.3-70b-instruct:free
LLM_MODEL=

# ─── Download Settings ───────────────────────────────────────────
OUTPUT_DIR=./output

# Browser to extract cookies from (chrome, firefox, safari, edge)
COOKIE_BROWSER=firefox

# ─── Optional: Udemy credentials (only if not using browser cookies)
# UDEMY_USERNAME=your_email@example.com
# UDEMY_PASSWORD=your_password
